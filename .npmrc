# uni-app 的 vite/esbuild 解析不了 pnpm 默认的隔离式 node_modules（依赖藏在 .pnpm/ 里），
# 会报 element-plus 的依赖 "Could not resolve dayjs/@vueuse/core/..."。
# shamefully-hoist=true 把依赖提升到扁平根 node_modules（与主项目 talk-ai 的 npm 扁平结构一致），
# 让 uni-app 能正常解析。详见 https://pnpm.io/npmrc#shamefully-hoist
shamefully-hoist=true
strict-peer-dependencies=false
